{
  "manifest_version": 3,
  "name": "ModernSysacad",
  "version": "1.3",
  "description": "Moderniza la interfaz del SYSACAD de las distintas Facultades Regionales de UTN.",
  "content_scripts": [
    {
      "matches": [
        "https://sysacad.frt.utn.edu.ar/*"
      ],
      "css": [
        "style.css"
      ],
      "js": [
        "content.js"
      ]
    },
    {
      "matches": [
        "https://sysacadweb.frre.utn.edu.ar/*"
      ],
      "css": [
        "frre.css"
      ],
      "js": [
        "frre.js"
      ]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "icons/*"
      ],
      "matches": [
        "https://sysacad.frt.utn.edu.ar/*",
        "https://sysacadweb.frre.utn.edu.ar/*"
      ]
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "modernsysacad@frt.utn.edu.ar",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  }
}
